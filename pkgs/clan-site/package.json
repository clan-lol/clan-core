{
  "name": "clan-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "imports": {
    "#config": "./clan-site.config.ts",
    "#lib/*.ts": "./src/lib/*.ts"
  },
  "engines": {
    "node": ">= 22.16.0"
  },
  "engineStrict": true,
  "scripts": {
    "dev": "MODE=development vite dev --configLoader native --host --strictPort",
    "build": "MODE=production vite build --configLoader native",
    "prelint": "MODE=production vite build --configLoader native",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint --flag unstable_native_nodejs_ts_config --concurrency auto",
    "lint:typescript": "svelte-check",
    "lint:stylelint": "stylelint '**/*.css' '**/*.svelte' --ignore-path .gitignore",
    "lint-fix": "prettier --write . && eslint --flag unstable_native_nodejs_ts_config --concurrency auto --fix && stylelint '**/*.css' '**/*.svelte' --ignore-path .gitignore --fix && svelte-check"
  },
  "devDependencies": {
    "@clan.lol/coding-standard-svelte": "workspace:*",
    "@clan.lol/svelte-md": "workspace:*",
    "@clan.lol/vite-plugin-pagefind": "workspace:*",
    "@clan.lol/vite-plugin-replace": "workspace:*",
    "@csstools/postcss-global-data": "^4.0.0",
    "@poppanator/sveltekit-svg": "^6.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "modern-normalize": "^3.0.1",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
    "postcss-preset-env": "^11.1.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.3.0",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-value": "workspace:*"
  }
}
